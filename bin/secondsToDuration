#!/bin/bash

: ${WORKDAY_SECONDS:=28800}; export WORKDAY_SECONDS
: ${WORKWEEK_SECONDS:=$((WORKDAY_SECONDS * 5))}; export WORKWEEK_SECONDS
: ${WORKMONTH_SECONDS:=$((WORKWEEK_SECONDS * 4))}; export WORKMONTH_SECONDS
: ${WORKYEAR_SECONDS:=$((WORKMONTH_SECONDS * 12))}; export WORKYEAR_SECONDS
: ${WORKGENERATION_SECONDS:=$((WORKYEAR_SECONDS * 38))}; export WORKGENERATION_SECONDS
: ${WORK_PREFIX:=w}; export WORK_PREFIX

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" '[--prefer-clock] [-x|--factor N] [-W|--workday] [--long-units] [--precision|-p N|[U|Z][.N](w|d|h|m|s) | --precision-width|-P WIDTH] [-w|--width [+]WIDTH] [--] SECONDS [...] [-?|-h|--help]'
    echo
    printf 'Usage: cat FILE [...] | %q %s\n' "$(basename "$1")" '[...] [-u|--unbuffered] [-s|--skip SKIP&PATTERN [...]] [-m|--match MATCH&PATTERN [...]]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Treat any integer in the input as seconds and convert them into
[Gg ][Yy ][MOmo ][Ww ][Dd ] [Hh ][Mm ][Ss]|[HH:]MM:SS.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --prefer-clock	    Use [HH:]MM:SS format even when minutes or seconds
			    are zero. (This yields a more steady output when
			    counting elapsed time.)
    --factor|-x N	    Multiply the found integers with N (e.g. 60 for
			    minutes) to obtain seconds.
    --workday|-W	    Render days and larger units as working days
			    (comprised of $((WORKDAY_SECONDS / 3600)) hours, not 24) instead of calendar
			    days, and adapt the unit (1${WORK_PREFIX}d, not 1d), too.
			    The exact counting can be configured via
			    \$WORKDAY_SECONDS, \$WORKWEEK_SECONDS,
			    \$WORKMONTH_SECONDS, \$WORKYEAR_SECONDS,
			    \$WORKGENERATION_SECONDS; prefix is \$WORK_PREFIX.
    --long-units	    Use "2 minutes" instead of "2m".
    --precision N	    No more than N units will be used in expressing the
			    duration.
    --precision|-p [U|Z][.N](g|y|mo|w|d|h|m|s)
			    Render purely as the passed unit [with N digits
			    right of the decimal point]. A "U" sigil rounds up,
			    a "Z" down towards zero; default is to nearest, ties
			    to even.
    --precision-width|-P WIDTH
			    Remove smaller units so that the result will fit
			    WIDTH; for example "01:02:03" will be rendered as
			    "1h 2m", with "3s" removed to fit a width of 7.
			    For human-readable output, use 7 (or 8 if you prefer
			    "01:02:03" over "1h 2m").
    --width|-w WIDTH	    Ensure a fixed width of WIDTH or the width of the
			    original integer and preceding spaces, whatever is
			    larger (so that alignment is not disturbed) by
			    adding space padding to the left.
    --width|-w +WIDTH	    Ensure a fixed width of the original integer and
			    any preceding spaces + WIDTH (so that alignment is
			    not disturbed) by adding space padding to the left.
    --unbuffered|-u	    Immediately output each read line.
    --skip|-s SKIP&PATTERN  Do not convert if the text around the integer (with
			    the integer itself and any preceding spaces
			    represented by &) matches SKIP&PATTERN.
    --match|-m MATCH&PATTERN
			    Only convert if the text around the integer (with
			    the integer itself and any preceding spaces
			    represented by &) matches MATCH&PATTERN. Other
			    occurrences (and those that also match --skip
			    SKIP&PATTERN) are not converted.
PATTERN is an AWK-style extended regular expression.
HELPTEXT
}

isPreferClock=
isBuffered=t
skipPattern=
matchPattern=
width=
precision=
precisionWidth=
factor=1
isWorkDay=
isShortUnits=t
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--prefer-clock)	shift; isPreferClock=t;;
	--unbuffered|-u)
			shift; isBuffered=;;
	--skip|-s)	shift; skipPattern+="${skipPattern:+|}${1:?}"; shift;;
	--match|-m)	shift; matchPattern+="${matchPattern:+|}${1:?}"; shift;;
	--width|-w)	shift; width="$1"; shift;;
	--precision|-p)	shift; precision="$1"; shift;;
	--precision-width|-P)
			shift; precisionWidth="$1"; shift;;
	--factor|-x)	shift; factor="${1:?}"; shift;;
	--workday|-W)	shift; isWorkDay=t;;
	--long-units)	shift; isShortUnits=;;
	--)		break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done
if [ -n "$precision" -a -n "$precisionWidth" ]; then
    echo 'ERROR: Cannot use both --precision and --precision-width.'; echo; printUsage "$0" >&2
    exit 2
fi

awk -F $'\n' \
    --bignum \
    -v "isPreferClock=$isPreferClock" \
    -v "isBuffered=$isBuffered" \
    -v "skipPattern=${skipPattern//\\/\\\\}" \
    -v "matchPattern=${matchPattern//\\/\\\\}" \
    -v "widthArg=$width" \
    -v "precision=$precision" \
    -v "precisionWidth=$precisionWidth" \
    -v "factor=$factor" \
    -v "isWorkDay=$isWorkDay" \
    -v "isShortUnits=$isShortUnits" \
'
function max(n1, n2)
{
    return n1 > n2 ? n1 : n2
}
function plural(count, what, pluralEnding, singularPadding) {
    return what (count == 1 ? singularPadding : (pluralEnding == "" ? "s" : pluralEnding))
}
function getWidth(seconds)
{
    if (widthArg == "") {
	return ""
    } else if (widthArg ~ /^\+/) {
	return length(seconds) + widthArg
    } else {
	return max(widthArg, length(seconds))
    }
}
function round(integer, rounder)
{
    return (rounder == 1 ? integer : int(integer / rounder + 0.5) * rounder)
}
function convert(integer, rounder, isPreferClock,      seconds, hours, minutes, days, weeks, months, years, generations, renderedDuration, secondUnit, hourUnit, minuteUnit, dayUnit, weekUnit, monthUnit, yearUnit, generationUnit)
{
    seconds = round(integer, rounder)

    generations = int(seconds / GENERATION_IN_SECONDS)
    seconds = round(seconds - (GENERATION_IN_SECONDS * generations), rounder)

    years = int(seconds / YEAR_IN_SECONDS)
    seconds = round(seconds - (YEAR_IN_SECONDS * years), rounder)

    months = int(seconds / MONTH_IN_SECONDS)
    seconds = round(seconds - (MONTH_IN_SECONDS * months), rounder)

    weeks = int(seconds / WEEK_IN_SECONDS)
    seconds = round(seconds - (WEEK_IN_SECONDS * weeks), rounder)

    days = int(seconds / DAY_IN_SECONDS)
    seconds = round(seconds - (DAY_IN_SECONDS * days), rounder)

    hours = int(seconds / 3600)
    seconds = round(seconds - (3600 * hours), rounder)

    minutes = int(seconds / 60)
    seconds = round(seconds - (60 * minutes), rounder)

    # Cannot use a space between the number and the unit yet, because the
    # precision counting relies on each unit being a single word; the
    # tempUnitSeparator will be replaced with a space in the end.
    generationUnit = (isShortUnits ? workdayPrefix "g" : tempUnitSeparator workdayPrefix plural(generations, "generation"))
    yearUnit = (isShortUnits ? workdayPrefix "y" : tempUnitSeparator workdayPrefix plural(years, "year"))
    monthUnit = (isShortUnits ? workdayPrefix "mo" : tempUnitSeparator workdayPrefix plural(months, "month"))
    weekUnit = (isShortUnits ? workdayPrefix "w" : tempUnitSeparator workdayPrefix plural(weeks, "week"))
    dayUnit = (isShortUnits ? workdayPrefix "d" : tempUnitSeparator workdayPrefix plural(days, "day"))
    hourUnit = (isShortUnits ? "h" : tempUnitSeparator plural(hours, "hour"))
    minuteUnit = (isShortUnits ? "m" : tempUnitSeparator plural(minutes, "minute"))
    secondUnit = (isShortUnits ? "s" : tempUnitSeparator plural(seconds, "second"))

    if ((hours == 0 || minutes == 0 || seconds == 0) && ! isPreferClock) {
	renderedDuration = gensub(\
		/ $/, "", 1, \
		(generations > 0 ? generations generationUnit " " : "") \
		    (years > 0 ? years yearUnit " " : "") \
		    (months > 0 ? months monthUnit " " : "") \
		    (weeks > 0 ? weeks weekUnit " " : "") \
		    (days > 0 ? days dayUnit " " : "") \
		    (hours > 0 ? hours hourUnit" " : "") \
		    (minutes > 0 ? minutes minuteUnit " " : "") \
		    (seconds > 0 ? seconds secondUnit " " : ""))
	return (renderedDuration == "" ? "0" secondUnit : renderedDuration)
    } else {
	return (generations > 0 ? generations generationUnit " " : "") \
		(years > 0 ? years yearUnit " " : "") \
		(months > 0 ? months monthUnit " " : "") \
		(weeks > 0 ? weeks weekUnit " " : "") \
		(days > 0 ? days dayUnit " " : "") \
		(generations > 0 || years > 0 || months > 0 || weeks > 0 || days > 0 || hours > 0 ? sprintf("%02d", hours) ":" : "") \
		(generations > 0 || years > 0 || months > 0 || weeks > 0 || days > 0 || hours > 0 || minutes > 0 ? sprintf("%02d", minutes) ":" : "") \
		(generations > 0 || years > 0 || months > 0 || weeks > 0 || days > 0 || hours > 0 || minutes > 0 ? sprintf("%02d", seconds) : sprintf("00:%02d", seconds))
    }
}
function shallowclone(target, source,      e)
{
    for (e in source) target[e] = source[e]
}
function join(n, list, seps,      i, result)
{
    for (i = 1; i <= n; ++i) {
	result = result list[i] seps[i]
    }
    result = result list[++i]
    return result
}
function repeat(text, count,      tmp, i)
{
    for (i = 1; i <= count; ++i) tmp = tmp text
    return tmp
}
function hasPrecisionUnitCount(duration)
{
    return (gsub(/[ :]/, "&", duration) + 1 > int(precision))
}
function hasPrecisionWidth(duration)
{
    return (length(duration) > precisionWidth)
}
function format(integer, width, isSpacePadded,      precisionParse, precisionSigil, duration, c)
{
    integer *= factor
    duration = convert(integer, 1, isPreferClock)

    if (match(precision, /^([UZ])?(\.([0-9]+))?(mo|[smhdwyg])$/, precisionParse)) {
	precisionSigil = precisionParse[4]
	if (precisionParse[1] != "") {
	    ROUNDMODE = precisionParse[1]
	}
	duration = sprintf("%." precisionParse[3] "f%s", integer / dividers[precisionSigil], workDayPrefix precisionSigil)
    } else if (int(precision) > 0) {
	for (c = 0; c <= length(rounder) && hasPrecisionUnitCount(duration); ++c) {
	    duration = convert(integer, rounder[c], isPreferClock)
	    if (isPreferClock && hasPrecisionUnitCount(duration)) {
		duration = convert(integer, rounder[c], 0)
	    }
	}
    } else if (int(precisionWidth) > 0) {
	for (c = 0; c <= length(rounder) + 1 && hasPrecisionWidth(duration); ++c) {
	    if (rounder[c]) {
		duration = convert(integer, rounder[c], isPreferClock)
		if (isPreferClock && hasPrecisionWidth(duration)) {
		    duration = convert(integer, rounder[c], 0)
		}
	    } else {
		duration = repeat("#", precisionWidth)
	    }
	}
    } else if (precision != "") {
	printf("Invalid precision: %s\n", precision) > "/dev/stderr"
	exit 2
    }

    duration = gensub(tempUnitSeparator, " ", "g", duration)

    if (isSpacePadded) duration = " " duration	# Ensure that there will be at least one space in front to maintain separation of preceding text.

    if (width == "" || length(duration) == width) return duration

    return sprintf("%" width "s", duration)
}
BEGIN {
    GENERATION_IN_SECONDS = (isWorkDay ? ENVIRON["WORKGENERATION_SECONDS"] : 31556952 * 30)
    YEAR_IN_SECONDS = (isWorkDay ? ENVIRON["WORKYEAR_SECONDS"] : 31536000)
    MONTH_IN_SECONDS = (isWorkDay ? ENVIRON["WORKMONTH_SECONDS"] : 2628000)
    WEEK_IN_SECONDS = (isWorkDay ? ENVIRON["WORKWEEK_SECONDS"] : 604800)
    DAY_IN_SECONDS = (isWorkDay ? ENVIRON["WORKDAY_SECONDS"] : 86400)
    workDayPrefix = (isWorkDay ? ENVIRON["WORK_PREFIX"] : "")

    dividers["s"] = 1
    dividers["m"] = 60
    dividers["h"] = 3600
    dividers["d"] = DAY_IN_SECONDS
    dividers["w"] = WEEK_IN_SECONDS
    dividers["mo"] = MONTH_IN_SECONDS
    dividers["y"] = YEAR_IN_SECONDS
    dividers["g"] = GENERATION_IN_SECONDS

    rounder[0] = 1
    rounder[1] = 60
    rounder[2] = 3600
    rounder[3] = DAY_IN_SECONDS
    rounder[4] = WEEK_IN_SECONDS
    rounder[5] = MONTH_IN_SECONDS
    rounder[6] = YEAR_IN_SECONDS
    rounder[7] = GENERATION_IN_SECONDS

    tempUnitSeparator = "_"

    if (ARGC > 1) {
	i = 1
	if (ARGV[1] == "--" ) ++i
	for (; i < ARGC; ++i) {
	    print format(ARGV[i], getWidth(ARGV[i]), 0)
	}
	exit 0
    }
}
{
    n = split($0, rest, / *\<[[:digit:]]+\>/, numbers)
    for (i = 1; i < n; ++i) {
	if (skipPattern != "" || matchPattern != "") {
	    shallowclone(testNumbers, numbers)
	    testNumbers[i] = "&"
	    testJoin = join(n, rest, testNumbers)
	    if (skipPattern != "" && testJoin ~ skipPattern) continue
	    if (matchPattern != "" && testJoin !~ matchPattern) continue
	}

	numbers[i] = format(numbers[i], getWidth(numbers[i]), (numbers[i] ~ /^ /))
    }

    $0 = join(n, rest, numbers)
    print
    if (! isBuffered) fflush()
}
' "$@"
