#!/bin/bash

: ${WORKDAY_SECONDS:=28800}; export WORKDAY_SECONDS
: ${WORKWEEK_SECONDS:=$((WORKDAY_SECONDS * 5))}; export WORKWEEK_SECONDS
: ${WORKMONTH_SECONDS:=$((WORKWEEK_SECONDS * 4))}; export WORKMONTH_SECONDS
: ${WORKYEAR_SECONDS:=$((WORKMONTH_SECONDS * 12))}; export WORKYEAR_SECONDS
: ${WORKGENERATION_SECONDS:=$((WORKYEAR_SECONDS * 38))}; export WORKGENERATION_SECONDS
: ${WORK_PREFIX=w}; export WORK_PREFIX

readonly formatParameterTemplate="\"${DURATIONTOSECONDS_ACCEPT_SIGN:+[+-]}${DURATIONTOSECONDS_ACCEPT_NEGATIVE:+[-]}[G_g ][Y_y ][MO_mo ][W_w ]([D_d ]([HH:]MM:SS|[Hh ][Mm ][Ss${DURATIONTOSECONDS_ACCEPT_FRACTIONAL:+ }]${DURATIONTOSECONDS_ACCEPT_FRACTIONAL:+[MSms]}))|D-[HH:]MM:SS${DURATIONTOSECONDS_ACCEPT_FRACTIONAL:+[.MS]}\""
readonly formatParameter="${formatParameterTemplate//_/${WORK_PREFIX:+[}${WORK_PREFIX}${WORK_PREFIX:+]}}"
getShortUsage()
{
    case "$1" in
	format)
	    printf %s "$formatParameter";;
	*)  echo "ERROR: Unknown short usage topic \"$1\"!" >&2; exit 2;;
    esac
}
printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: [DURATIONTOSECONDS_ACCEPT_NEGATIVE=1|t|true|DURATIONTOSECONDS_ACCEPT_SIGN=1|t|true] [DURATIONTOSECONDS_ACCEPT_FRACTIONAL=1|t|true] %q %s\n' "$(basename "$1")" "$formatParameter [...] [-?|-h|--help]"
    printf 'Usage: cat FILE [...] | %q %s\n' "$(basename "$1")" '[-u|--unbuffered] [-s|--skip SKIP&PATTERN [...]] [-m|--match MATCH&PATTERN [...]]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Convert passed / matches of enumerations of N g(enerations) / y(ears) / mo(nths)
/ d(ays) ${WORK_PREFIX:+(preceding units optionally prefixed with '$WORK_PREFIX' for work-times, e.g.
'${WORK_PREFIX}d' for working days) }/ h(ours) / m(inutes) / s(econds)${DURATIONTOSECONDS_ACCEPT_FRACTIONAL:+ / m(illi)s(econds)} or
[Dd |D-][HH:]MM:SS${DURATIONTOSECONDS_ACCEPT_FRACTIONAL:+[.MS]} into seconds.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --unbuffered|-u	    Immediately output each read line.
    --skip|-s SKIP&PATTERN  Do not convert if the text around the duration (with
			    the duration itself represented by &) matches
			    SKIP&PATTERN.
    --match|-m MATCH&PATTERN
			    Only convert if the text around the duration (with
			    the duration itself represented by &) matches
			    MATCH&PATTERN. Other occurrences (and those that
			    also match --skip SKIP&PATTERN) are not converted.
PATTERN is an AWK-style extended regular expression.
HELPTEXT
}

isBuffered=t
skipPattern=
matchPattern=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--get-short-usage)
			shift; getShortUsage "$@"; exit 0;;

	--unbuffered|-u)
			shift; isBuffered=;;
	--skip|-s)	shift; skipPattern+="${skipPattern:+|}${1:?}"; shift;;
	--match|-m)	shift; matchPattern+="${matchPattern:+|}${1:?}"; shift;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done

awk -F $'\n' \
    -v "isBuffered=$isBuffered" \
    -v "skipPattern=${skipPattern//\\/\\\\}" \
    -v "matchPattern=${matchPattern//\\/\\\\}" \
    -v "signPattern=${DURATIONTOSECONDS_ACCEPT_SIGN:+[+-]}${DURATIONTOSECONDS_ACCEPT_NEGATIVE:+-}" \
    -v "isFractional=$DURATIONTOSECONDS_ACCEPT_FRACTIONAL" \
'
function convert(duration,      calendar, n, c, cc, clock, v, seconds, fractionalSeconds, hasMatch)
{
    n = split(gensub(/^.* /, "", 1, duration), clock, /:/)
    c = split(duration, calendar, / /)
    if (match(clock[1], /^[[:digit:]]+-/)) {
	calendar[c] = substr(clock[1], RSTART, RLENGTH - 1) "d"
	clock[1] = substr(clock[1], RSTART + RLENGTH)
    }

    seconds = 0
    fractionalSeconds = ""
    for (cc = 1; cc <= c; ++cc) {
	if (WP != "" && calendar[cc] ~ "^[[:digit:]]+" WP "g$") {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * ENVIRON["WORKGENERATION_SECONDS"]
	    hasMatch = 1
	    continue
	}
	if (calendar[cc] ~ /^[[:digit:]]+g$/) {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * 31556952 * 30
	    hasMatch = 1
	    continue
	}
	if (WP != "" && calendar[cc] ~ "^[[:digit:]]+" WP "y$") {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * ENVIRON["WORKYEAR_SECONDS"]
	    hasMatch = 1
	    continue
	}
	if (calendar[cc] ~ /^[[:digit:]]+y$/) {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * 31536000
	    hasMatch = 1
	    continue
	}
	if (WP != "" && calendar[cc] ~ "^[[:digit:]]+" WP "mo$") {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * ENVIRON["WORKMONTH_SECONDS"]
	    hasMatch = 1
	    continue
	}
	if (calendar[cc] ~ /^[[:digit:]]+mo$/) {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * 2628000
	    hasMatch = 1
	    continue
	}
	if (WP != "" && calendar[cc] ~ "^[[:digit:]]+" WP "w$") {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * ENVIRON["WORKWEEK_SECONDS"]
	    hasMatch = 1
	    continue
	}
	if (calendar[cc] ~ /^[[:digit:]]+w$/) {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * 604800
	    hasMatch = 1
	    continue
	}
	if (calendar[cc] ~ /^[[:digit:]]+d$/) {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * 86400
	    hasMatch = 1
	    continue
	}
	if (WP != "" && calendar[cc] ~ "^[[:digit:]]+" WP "d$") {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * ENVIRON["WORKDAY_SECONDS"]
	    hasMatch = 1
	    continue
	}
	if (calendar[cc] ~ /^[[:digit:]]+h$/) {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * 3600
	    hasMatch = 1
	    continue
	}
	if (calendar[cc] ~ /^[[:digit:]]+m$/) {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1) * 60
	    hasMatch = 1
	    continue
	}
	if (calendar[cc] ~ /^[[:digit:]]+s$/) {
	    seconds += substr(calendar[cc], 1, length(calendar[cc]) - 1)
	    hasMatch = 1
	    continue
	}
	if (isFractional && calendar[cc] ~ /^[[:digit:]]+ms$/) {
	    v = substr(calendar[cc], 1, length(calendar[cc]) - 1)
	    seconds += int(v / 1000)
	    fractionalSeconds = sprintf(".%03d", v % 1000)
	    hasMatch = 1
	    continue
	}
    }

    if (n == 2 || n == 3) {
	if (match(clock[n], /\.[[:digit:]]+$/)) {
	    seconds += int(substr(clock[n], 1, RSTART - 1))
	    fractionalSeconds = substr(clock[n], RSTART, RLENGTH)
	} else {
	    seconds += clock[n]
	}

	if (n == 2) {
	    seconds += clock[n - 1] * 60
	} else if (n == 3) {
	    seconds += clock[n - 2] * 3600 + clock[n - 1] * 60
	}

	hasMatch = 1
    }

    return (hasMatch ? seconds (fractionalSeconds ~ /^\.0+$/ ? "" : fractionalSeconds) : duration)
}
function shallowclone(target, source,      e)
{
    for (e in source) target[e] = source[e]
}
function join(n, list, seps,      i, result) {
    for (i = 1; i <= n; ++i) {
	result = result list[i] seps[i]
    }
    result = result list[++i]
    return result
}
BEGIN {
    WP = ENVIRON["WORK_PREFIX"]
    WP_OPTIONAL = (WP == "" ? "" : "(" WP ")?")
    DIGITS_WORK = "[[:digit:]]+" WP_OPTIONAL
    WEEK_AND_LONGER_PATTERN = "(" DIGITS_WORK "g )?(" DIGITS_WORK "y )?(" DIGITS_WORK "mo )?" DIGITS_WORK "w"
    WEEK_AND_LONGER_PATTERN = WEEK_AND_LONGER_PATTERN "|(" DIGITS_WORK "g )?(" DIGITS_WORK "y )?" DIGITS_WORK "mo"
    WEEK_AND_LONGER_PATTERN = WEEK_AND_LONGER_PATTERN "|(" DIGITS_WORK "g )?" DIGITS_WORK "y"
    WEEK_AND_LONGER_PATTERN = WEEK_AND_LONGER_PATTERN "|" DIGITS_WORK "g"
    DAY_PATTERN = DIGITS_WORK "d"
    DAY_AND_TIME_PATTERN = "([[:digit:]]+(" WP_OPTIONAL "d |-))?[[:digit:]]+(:[[:digit:]]{2}){1,2}" (isFractional ? "(\\.[[:digit:]]{1,3})?" : "")
    HMSMS_PATTERN = "([[:digit:]]+h )?([[:digit:]]+m )?([[:digit:]]+s )?([[:digit:]]+ms)"
    HMS_PATTERN = "([[:digit:]]+h )?([[:digit:]]+m )?([[:digit:]]+s)"
    HM_PATTERN = "([[:digit:]]+h )?([[:digit:]]+m)"
    H_PATTERN = "([[:digit:]]+h)"

    DURATION_PATTERN = "((" WEEK_AND_LONGER_PATTERN ") )?(" DAY_AND_TIME_PATTERN \
	(isFractional ? "|(" DAY_PATTERN " )?" HMSMS_PATTERN : "") \
	"|(" DAY_PATTERN " )?" HMS_PATTERN \
	"|(" DAY_PATTERN " )?" HM_PATTERN \
	"|(" DAY_PATTERN " )?" H_PATTERN \
	"|(" DAY_PATTERN "))"
    DURATION_PATTERN = "(" DURATION_PATTERN "|" WEEK_AND_LONGER_PATTERN ")"

    if (ARGC > 1) {
	for (i = 1; i < ARGC; ++i) {
	    if (ARGV[i] ~ "^" DURATION_PATTERN "$")
		print convert(ARGV[i])
	    else if ( signPattern != "" && match(ARGV[i], "^(" signPattern ")" DURATION_PATTERN "$", submatches))
		print submatches[1] convert(substr(ARGV[i], 2))
	    else if (ARGV[i] ~ "^" (signPattern == "" ? "" : signPattern "?") "[[:digit:]]+$")
		print ARGV[i]
	    else
		status = 1
	}
	exit status
    }
}
{
    n = split($0, rest, "\\<" DURATION_PATTERN "\\>", durations)

    for (i = 1; i < n; ++i) {
	if (skipPattern != "" || matchPattern != "") {
	    shallowclone(testDurations, durations)
	    testDurations[i] = "&"
	    testJoin = join(n, rest, testDurations)
	    if (skipPattern != "" && testJoin ~ skipPattern) continue
	    if (matchPattern != "" && testJoin !~ matchPattern) continue
	}

	durations[i] = convert(durations[i])
    }

    $0 = join(n, rest, durations)
    print
    if (! isBuffered) fflush()
}
' "$@"
